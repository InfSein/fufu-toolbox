<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="fufu_toolbox.Pages.PortManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:fufu_toolbox.Models"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="30" FontWeight="SemiBold" Text="端口管理" />

        <Border
            Grid.Row="1"
            Padding="14"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="FilterTextBox"
                    Grid.Column="0"
                    Header="按端口号或程序名筛选"
                    PlaceholderText="例如：8080 或 nginx"
                    Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextChanged="FilterTextBox_TextChanged" />

                <Button
                    Grid.Column="1"
                    Margin="0,24,0,0"
                    Content="刷新"
                    Click="RefreshButton_Click" />
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Padding="12"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Opacity="0.75" Text="{x:Bind ViewModel.Summary, Mode=OneWay}" />

                <Grid Grid.Row="1">
                    <ListView
                        ItemsSource="{x:Bind ViewModel.PortItems, Mode=OneWay}"
                        SelectionMode="None"
                        ScrollViewer.VerticalScrollMode="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PortOccupancyItem">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                            <Image Source="{x:Bind ProcessIcon, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind ProcessName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind ExecutablePath}" FontSize="12" Opacity="0.7" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="端口" Opacity="0.7" FontSize="12" />
                                            <TextBlock Text="{x:Bind Port}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="协议/PID" Opacity="0.7" FontSize="12" />
                                            <TextBlock>
                                                <Run Text="{x:Bind Protocol}" />
                                                <Run Text=" / " />
                                                <Run Text="{x:Bind ProcessId}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <Button
                                            Grid.Column="4"
                                            VerticalAlignment="Center"
                                            Content="中止程序"
                                            Tag="{Binding}"
                                            Click="TerminateProcessButton_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid
                        Background="#66000000"
                        Visibility="{x:Bind ViewModel.RefreshMaskVisibility, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                            <ProgressRing IsActive="True" Width="36" Height="36" />
                            <TextBlock Foreground="White" Text="正在刷新，请稍候..." />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
