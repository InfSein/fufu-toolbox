<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="fufu_toolbox.Pages.MergeTxtPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:fufu_toolbox.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="30" FontWeight="SemiBold" Text="合并TXT" />

        <Border
            Grid.Row="1"
            Padding="14"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <StackPanel Spacing="10">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="选择目录" Click="PickFolderButton_Click" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        Text="{x:Bind ViewModel.SelectedFolderPath, Mode=OneWay}" />
                </Grid>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Opacity="0.75" VerticalAlignment="Center" Text="{x:Bind ViewModel.ScanSummary, Mode=OneWay}" />
                    <Button Grid.Column="1" Content="全选" Click="SelectAllButton_Click" />
                    <Button Grid.Column="2" Content="反选" Click="InvertSelectButton_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="2"
            Padding="12"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="选择" />
                    <TextBlock Grid.Column="1" Text="文件" />
                    <TextBlock Grid.Column="2" Text="预览" />
                    <TextBlock Grid.Column="3" Text="别名" />
                    <TextBlock Grid.Column="4" Text="调整" />
                </Grid>

                <ListView
                    Grid.Row="1"
                    x:Name="FileListView"
                    MinHeight="260"
                    ItemsSource="{x:Bind ViewModel.Files, Mode=OneWay}"
                    SelectionMode="None"
                    ScrollViewer.VerticalScrollMode="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MergeTxtFileItem">
                            <Border
                                Margin="0,0,0,8"
                                Padding="8"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind FileName}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind FilePath}" Opacity="0.65" FontSize="12" TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="预览" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <ToolTipService.ToolTip>
                                            <ToolTip>
                                                <Border Padding="8" MaxWidth="640">
                                                    <TextBlock FontFamily="Consolas" TextWrapping="Wrap" Text="{x:Bind PreviewText}" />
                                                </Border>
                                            </ToolTip>
                                        </ToolTipService.ToolTip>
                                    </Button>

                                    <TextBox
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        PlaceholderText="可选，填 - 表示不输出标题"
                                        Text="{x:Bind Alias, Mode=TwoWay}" />

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="上移" Click="MoveUpButton_Click" Tag="{Binding}" />
                                        <Button Content="下移" Click="MoveDownButton_Click" Tag="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="合并顺序以列表当前顺序为准；别名留空用原文件名，填 - 则跳过标题。" Opacity="0.75" />
            <Button
                Grid.Column="1"
                Content="合并并另存为"
                IsEnabled="{x:Bind ViewModel.CanMerge, Mode=OneWay}"
                Click="MergeAndSaveButton_Click" />
        </Grid>
    </Grid>
</Page>
