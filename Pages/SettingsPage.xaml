<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="fufu_toolbox.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style TargetType="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
            <TextBlock FontSize="32" FontWeight="SemiBold" Text="设置" />
            <TextBlock Opacity="0.82" Text="按分组管理配置，分组支持折叠，方便后续继续增加选项。" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <Expander IsExpanded="True">
                    <Expander.Header>
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE771;" />
                            <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="外观" />
                        </Grid>
                    </Expander.Header>
                    <Border
                        Margin="0,10,0,0"
                        Padding="16"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock FontWeight="SemiBold" Text="应用主题" />
                                <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="选择跟随系统、浅色或深色。切换后会立即生效。" />
                            </StackPanel>
                            <ComboBox
                                Grid.Column="1"
                                Width="220"
                                VerticalAlignment="Center"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}" />
                        </Grid>
                    </Border>
                </Expander>

                <Expander>
                    <Expander.Header>
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE713;" />
                            <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="通用" />
                        </Grid>
                    </Expander.Header>
                    <Border
                        Margin="0,10,0,0"
                        Padding="16"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold" Text="开机启动" />
                                    <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="应用随系统启动。该设置预留，后续开放。" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="False" IsEnabled="False" />
                            </Grid>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold" Text="默认输出目录" />
                                    <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="设置工具输出内容的默认保存位置。该设置预留。" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Width="260" VerticalAlignment="Center" PlaceholderText="后续可配置" IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <Expander>
                    <Expander.Header>
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE7EF;" />
                            <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="高级" />
                        </Grid>
                    </Expander.Header>
                    <Border
                        Margin="0,10,0,0"
                        Padding="16"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold" Text="调试模式" />
                                    <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="开启后显示更详细的调试信息。该设置预留。" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="False" IsEnabled="False" />
                            </Grid>

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold" Text="实验功能" />
                                    <TextBlock Opacity="0.75" TextWrapping="Wrap" Text="试用尚未稳定的功能。该设置预留。" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="False" IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
